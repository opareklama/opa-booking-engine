<?xml version="1.0"?>
<ruleset name="OpaBookingEngine">
    <description>WordPress Coding Standards for Opa Booking Engine</description>

    <!-- Scan these directories -->
    <file>./src</file>
    <file>./opa-booking.php</file>

    <!-- Exclude third-party libraries -->
    <exclude-pattern>./vendor/*</exclude-pattern>
    <exclude-pattern>./node_modules/*</exclude-pattern>

    <!-- How to scan -->
    <arg value="sp"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>

    <!-- Rules -->
    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Docs"/>
    <rule ref="WordPress-Extra"/>

    <!-- Custom configurations for namespace and text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="opa-booking"/>
        </properties>
    </rule>

    <!-- Ignore filename rules as PSR-4 uses class names for files -->
    <rule ref="WordPress.Files.FileName">
        <severity>0</severity>
    </rule>
</ruleset>
